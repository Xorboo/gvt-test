{{- /* GVT fork: index description + speaker so talks are searchable by topic and speaker name */ -}}
{{- $.Scratch.Add "index" slice -}}
{{- range site.RegularPages -}}
  {{- if and (not .Params.searchHidden) (ne .Layout `archives`) (ne .Layout `search`) }}
    {{- $.Scratch.Add "index" (dict "title" .Title "content" .Plain "permalink" .Permalink "summary" .Summary "description" (.Description | plainify) "speaker" (printf "%s %s" (.Params.speaker | default "") (.Params.speakerInfo | default "" | plainify))) -}}
  {{- end }}
{{- end -}}
{{- $.Scratch.Get "index" | jsonify -}}
